@model IEnumerable<ProRental.Domain.Entities.Product>

@{
    ViewData["Title"] = "Product Catalog";
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
    var search = ViewBag.Search as string;
    var searchField = ViewBag.SearchField as string;
    var sortField = ViewBag.SortField as string;
    var sortDir = ViewBag.SortDir as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Product Catalog</h2>
    <a asp-action="Create" class="btn btn-primary">Create Product</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form method="get" asp-action="Index" class="row g-2 mb-4">
    <div class="col-md-3">
        <select name="searchField" class="form-select">
            <option value="">Search By</option>
            <option value="sku" selected="@(searchField == "sku")">SKU</option>
            <option value="category" selected="@(searchField == "category")">Category</option>
            <option value="status" selected="@(searchField == "status")">Status</option>
        </select>
    </div>
    <div class="col-md-4">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Search..." />
    </div>
    <div class="col-md-2">
        <select name="sortField" class="form-select">
            <option value="">Sort By</option>
            <option value="sku" selected="@(sortField == "sku")">SKU</option>
            <option value="createdat" selected="@(sortField == "createdat")">Created Date</option>
            <option value="threshold" selected="@(sortField == "threshold")">Threshold</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="sortDir" class="form-select">
            <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
            <option value="desc" selected="@(sortDir == "desc")">Descending</option>
        </select>
    </div>
    <div class="col-md-1 d-grid">
        <button type="submit" class="btn btn-outline-primary">Go</button>
    </div>
</form>

<table class="table table-striped table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>SKU</th>
            <th>Category</th>
            <th>Name</th>
            <th>Status</th>
            <th>Threshold</th>
            <th>Price</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
    @if (Model != null && Model.Any())
    {
        @foreach (var product in Model)
        {
            var detail = product.GetProductdetail();
            var category = product.GetCategoryEntity();

            <tr>
                <td>@product.GetProductId()</td>
                <td>@product.GetSku()</td>
                <td>@product.GetCategoryId()</td>
                <td>@(detail?.GetName() ?? "-")</td>
                <td>@product.GetStatus()</td>
                <td>@((product.GetThreshold() * 100m).ToString("0.##"))%</td>
                <td>@((detail?.GetPrice() ?? 0m).ToString("0.00"))</td>
                <td>
                    <a asp-action="Details" asp-route-id="@product.GetProductId()" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@product.GetProductId()" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@product.GetProductId()" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="8" class="text-center">No products found.</td>
        </tr>
    }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@search"
                       asp-route-searchField="@searchField"
                       asp-route-sortField="@sortField"
                       asp-route-sortDir="@sortDir">@i</a>
                </li>
            }
        </ul>
    </nav>
}