@model IEnumerable<ProRental.Domain.Entities.Category>

@{
    ViewData["Title"] = "Category Catalog";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">Category Management</h1>

    <div class="card shadow-sm mb-5">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Create New Category</h5>
        </div>
        <div class="card-body">
            <form asp-controller="CategoryCatalog" asp-action="HandleCategoryCRUD" method="post">
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Category Name</label>
                        <input type="text" name="categoryName" class="form-control" placeholder="e.g. Camera" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Description</label>
                        <input type="text" name="categoryDescription" class="form-control" placeholder="e.g. Digital SLR Cameras" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success px-4">Save Category</button>
            </form>
        </div>
    </div>

    <hr />

    <h2 class="mt-4">Category List</h2>
    <div class="table-responsive">
        <table class="table table-hover mt-3 shadow-sm">
            <thead class="thead-light">
                <tr>
                    <th style="width: 30%">Category Name</th>
                    <th style="width: 50%">Description</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.GetName()</td>
                            <td class="align-middle text-muted">@(item.GetDescription() ?? "No description")</td>
                            <td class="text-end align-middle">
                                <form asp-controller="CategoryCatalog" asp-action="Delete" method="post" 
                                      onsubmit="return confirm('Delete this category?');" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.GetCategoryId()" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No categories found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>