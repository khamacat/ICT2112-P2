@model ProRental.Domain.Entities.Purchaseorder

@{
    ViewData["Title"] = "Supplier Purchase Order";
}

<div class="container py-4">
    <h1 class="text-dark">Purchase Order page loaded</h1>
    <p class="text-dark">Request ID: @ViewBag.RequestId</p>

    @if (Model == null)
    {
        <div class="alert alert-info">
            Model is null
        </div>

        <form method="post" asp-action="BuildDraft">
            <input type="hidden" name="reqId" value="@ViewBag.RequestId" />

            <div class="mb-3">
                <label class="form-label text-dark">Supplier ID</label>
                <input type="number" name="supplierId" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-primary">Build Draft</button>
        </form>
    }
    else
    {
        <div class="alert alert-success">
            Model loaded successfully
        </div>
    }
</div>