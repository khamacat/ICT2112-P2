@model IReadOnlyList<ProRental.Domain.Entities.Alert>

@{
    ViewData["Title"] = "Inventory Alerts";
    var filter = ViewData["Filter"]?.ToString() ?? "All Alerts";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Inventory Alerts</h2>
            <small class="text-muted">@filter</small>
        </div>
        <a asp-controller="StaffInventory" asp-action="DisplayInventoryList" class="btn btn-outline-secondary btn-sm">Back to Staff Inventory</a>
    </div>

    @if (TempData["Message"] is string message)
    {
        <div class="alert alert-info">@message</div>
    }

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-action="DisplayAllAlerts" class="btn btn-primary btn-sm">Display All Alerts</a>
        <a asp-action="DisplayAllThresholds" class="btn btn-outline-primary btn-sm">Display All Thresholds</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Alert ID</th>
                    <th>Product ID</th>
                    <th>Threshold</th>
                    <th>Current Stock</th>
                    <th>Status</th>
                    <th>Message</th>
                    <th>Created</th>
                    <th>Resolved</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted">No alerts found.</td>
                    </tr>
                }
                else
                {
                    foreach (var alert in Model)
                    {
                        <tr>
                            <td>@alert.GetAlertId()</td>
                            <td>@alert.GetProductId()</td>
                            <td>@alert.GetMinThreshold()</td>
                            <td>@alert.GetCurrentStock()</td>
                            <td>@alert.GetAlertStatus()</td>
                            <td>@alert.GetMessage()</td>
                            <td>@alert.GetCreatedAt().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(alert.GetResolvedAt()?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <a asp-action="DisplayAlert" asp-route-alertId="@alert.GetAlertId()" class="btn btn-sm btn-outline-secondary">Display</a>

                                    <form asp-action="AcknowledgeAlert" asp-route-alertId="@alert.GetAlertId()" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Acknowledge</button>
                                    </form>

                                    <form asp-action="ResolveAlert" asp-route-alertId="@alert.GetAlertId()" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success">Resolve</button>
                                    </form>

                                    <form asp-action="EditThreshold" asp-route-alertId="@alert.GetAlertId()" method="post" class="d-flex gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="number" name="threshold" class="form-control form-control-sm" style="width: 90px;" min="0" value="@alert.GetMinThreshold()" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Edit Threshold</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
