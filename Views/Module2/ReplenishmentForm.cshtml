@model ProRental.Domain.Entities.Replenishmentrequest
@{
    var isNewRequest = Model.Lineitems == null || !Model.Lineitems.Any();
    ViewData["Title"] = isNewRequest ? "New Replenishment Request" : $"Edit Request #{Model.GetRequestId()}";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="List">Replenishment Requests</a></li>
            <li class="breadcrumb-item active">@(isNewRequest ? "New Request" : $"Edit #{Model.GetRequestId()}")</li>
        </ol>
    </nav>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        @*// Request Remarks are request-level notes. Line Item Remarks are per-product notes. Keep them separate. *@
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Request Details</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Request ID</dt>
                    <dd class="col-sm-7">#@Model.GetRequestId()</dd>

                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7"><span class="badge bg-secondary">Draft</span></dd>

                    <dt class="col-sm-5">Requested By</dt>
                    <dd class="col-sm-7">@Model.GetRequestedBy()</dd>

                    <dt class="col-sm-5">Created At</dt>
                    <dd class="col-sm-7">@Model.GetCreatedAt()?.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Add Product</h5>
            </div>
            <div class="card-body">
                <form asp-action="AddItem" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@Model.GetRequestId()" />

                    <div class="mb-3">
                        <label for="productId" class="form-label">Product ID</label>
                        <input type="number" class="form-control" id="productId" name="productId"
                               placeholder="Enter product ID" required min="1" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus me-1"></i>Add Item
                    </button>
                </form>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-chat-left-text me-2"></i>Request Remarks</h5>
            </div>
            <div class="card-body">
                <form asp-action="UpdateRequestRemarks" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requestId" value="@Model.GetRequestId()" />

                    <div class="mb-3">
                        <label for="requestRemarks" class="form-label">Overall request notes</label>
                        <textarea id="requestRemarks"
                                  name="remarks"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Add notes for the entire request (separate from line-item remarks).">@Model.GetRemarks()</textarea>
                    </div>

                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-save me-1"></i>Save Request Remarks
                    </button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Actions</h5>
            </div>
            <div class="card-body d-grid gap-2">
                @if (Model.HasLineItem())
                {
                    <form asp-action="Submit" asp-route-id="@Model.GetRequestId()" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-send me-1"></i>Submit Request
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-success w-100" disabled>
                        <i class="bi bi-send me-1"></i>Submit Request
                    </button>
                    <small class="text-muted">Add at least one item to submit</small>
                }

                <form asp-action="Cancel" asp-route-id="@Model.GetRequestId()" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100"
                            onclick="return confirm('Are you sure you want to cancel this request?')">
                        <i class="bi bi-x-circle me-1"></i>Cancel Request
                    </button>
                </form>

                <a asp-action="List" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Line Items</h5>
                <span class="badge bg-primary">@(Model.Lineitems?.Count() ?? 0) items</span>
            </div>
            <div class="card-body">
                @if (Model.Lineitems != null && Model.Lineitems.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Quantity</th>
                                    <th>Reason</th>
                                    <th>Line Item Remarks</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                 @foreach (var item in Model.Lineitems)
                                 {
                                      var formId = $"update-item-{item.GetLineItemId()}";
                                     <tr>
                                         <td>
                                              <strong>Product #@item.GetProductId()</strong>
                                            @if (item.Product?.GetProductdetail() != null)
                                            {
                                                <br /><small class="text-muted">@item.Product.GetProductdetail()!.GetName()</small>
                                            }
                                         </td>
                                         <td>
                                             <input type="number"
                                                    class="form-control form-control-sm"
                                                    style="width: 120px;"
                                                    form="@formId"
                                                    name="quantity"
                                                    value="@item.GetQuantityRequest()"
                                                    min="1"
                                                    required
                                                    onchange="document.getElementById('@formId').submit()" />
                                         </td>
                                         <td>
                                             <select name="reason"
                                                     class="form-select form-select-sm"
                                                     style="width: 160px;"
                                                     form="@formId"
                                                     onchange="document.getElementById('@formId').submit()">
                                                 @foreach (var reason in Enum.GetValues<ProRental.Domain.Enums.ReplenishmentReason>())
                                                 {
                                                     <option value="@reason" selected="@(item.Reason == reason)">@reason</option>
                                                 }
                                             </select>
                                         </td>
                                         <td>
                                             <input type="text"
                                                    class="form-control form-control-sm"
                                                    form="@formId"
                                                    name="remarks"
                                                    value="@item.GetRemarks()"
                                                    placeholder="Add remarks"
                                                    onchange="document.getElementById('@formId').submit()" />
                                         </td>
                                         <td>
                                             <form id="@formId" asp-action="UpdateItem" method="post" class="d-none">
                                                 @Html.AntiForgeryToken()
                                                  <input type="hidden" name="requestId" value="@Model.GetRequestId()" />
                                                  <input type="hidden" name="lineItemId" value="@item.GetLineItemId()" />
                                             </form>

                                             <form asp-action="RemoveItem" method="post" class="d-inline">
                                                 @Html.AntiForgeryToken()
                                                  <input type="hidden" name="requestId" value="@Model.GetRequestId()" />
                                                 <input type="hidden" name="lineItemId" value="@item.GetLineItemId()" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Remove this item?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                             </form>
                                         </td>
                                     </tr>
                                 }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox display-4"></i>
                        <p class="mt-3 mb-0">No items added yet.</p>
                        <p>Use the form on the left to add products to this request.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
