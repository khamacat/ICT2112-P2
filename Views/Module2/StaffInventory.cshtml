@using ProRental.Domain.Enums
@model IReadOnlyList<ProRental.Domain.Entities.Inventoryitem>

@{
    ViewData["Title"] = "Staff Inventory";
    var query = ViewData["Query"]?.ToString() ?? string.Empty;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Staff Inventory</h2>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#createInventoryModal">
                <i class="bi bi-plus-circle"></i> Create Item
            </button>
            <a asp-controller="InventoryAlerts" asp-action="DisplayAllAlerts" class="btn btn-outline-secondary btn-sm">View Alerts</a>
        </div>
    </div>

    @if (TempData["Message"] is string message)
    {
        <div class="alert alert-info">@message</div>
    }

    <form asp-action="HandleSearch" method="get" class="row g-2 mb-3">
        <div class="col-md-6">
            <input name="query" value="@query" class="form-control" placeholder="Search by inventory ID, product ID, or serial number" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
        <div class="col-auto">
            <a asp-action="DisplayInventoryList" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>

    <div>
        <div class="row g-2 mb-3">
            <div class="col-md-4">
                <select class="form-select" id="statusSelect">
                    <option value="" disabled selected>-- Select Status --</option>
                    @foreach (InventoryStatus statusEnum in Enum.GetValues(typeof(InventoryStatus)))
                    {
                        <option value="@statusEnum.ToString()">@statusEnum</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-warning" onclick="handleBulkStatusUpdate()">Update Status</button>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-danger" onclick="handleBulkDelete()">Delete Selected</button>
            </div>
        </div>

    <form>
        @Html.AntiForgeryToken()

        <div class="row g-2 mb-3">

        <div class="table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 36px;"></th>
                        <th>Inventory ID</th>
                        <th>Product ID</th>
                        <th>Serial Number</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">No inventory items found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" name="inventoryItemIds" value="@item.GetInventoryItemId()" />
                                </td>
                                <td>@item.GetInventoryItemId()</td>
                                <td>@item.GetProductId()</td>
                                <td>@item.GetSerialNumber()</td>
                                <td>@item.GetStatus()</td>
                                <td>@item.GetUpdatedDate().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="ShowProductDetails" asp-route-inventoryItemId="@item.GetInventoryItemId()" class="btn btn-sm btn-outline-primary">View</a>
                                        <form asp-action="DeleteInventoryItem" asp-route-inventoryItemId="@item.GetInventoryItemId()" method="post" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this item?');">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </form>
</div>

<!-- Create Inventory Item Modal -->
<div class="modal fade" id="createInventoryModal" tabindex="-1" aria-labelledby="createInventoryLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createInventoryLabel">Create Inventory Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateInventoryItemPost" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="productId" class="form-label">Product ID <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="productId" name="productId" required>
                    </div>
                    <div class="mb-3">
                        <label for="serialNumber" class="form-label">Serial Number <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="serialNumber" name="serialNumber" required maxlength="255">
                    </div>
                    <div class="mb-3">
                        <label for="status" class="form-label">Status</label>
                        <select class="form-select" id="status" name="status" asp-items="Html.GetEnumSelectList<ProRental.Domain.Enums.InventoryStatus>()">
                            <option value="">-- Select Status --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="expiryDate" class="form-label">Expiry Date</label>
                        <input type="date" class="form-control" id="expiryDate" name="expiryDate">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function handleBulkStatusUpdate() {
    const checkboxes = document.querySelectorAll('input[name="inventoryItemIds"]:checked');
    if (checkboxes.length === 0) {
        alert('Please select at least one item to update.');
        return;
    }
    
    const statusSelect = document.getElementById('statusSelect');
    if (!statusSelect || statusSelect.value === '' || statusSelect.value === null) {
        alert('Please select a valid status.');
        return;
    }
    
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '@Url.Action("HandleBulkOperation", "StaffInventory")';
    
    // Add anti-forgery token
    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
    const tokenInput = document.createElement('input');
    tokenInput.type = 'hidden';
    tokenInput.name = '__RequestVerificationToken';
    tokenInput.value = token;
    form.appendChild(tokenInput);
    
    // Add status
    const statusInput = document.createElement('input');
    statusInput.type = 'hidden';
    statusInput.name = 'status';
    statusInput.value = statusSelect.value;
    form.appendChild(statusInput);
    
    // Add selected item IDs
    checkboxes.forEach(checkbox => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'inventoryItemIds';
        input.value = checkbox.value;
        form.appendChild(input);
    });
    
    console.log('Form action:', form.action);
    console.log('Number of items:', checkboxes.length);
    console.log('Status:', statusSelect.value);
    
    document.body.appendChild(form);
    form.submit();
}

function validateBulkStatusForm() {
    try {
        console.log('Validating bulk status form...');
        
        const checkboxes = document.querySelectorAll('input[name="inventoryItemIds"]:checked');
        console.log('Checked boxes count:', checkboxes.length);
        
        if (!checkboxes || checkboxes.length === 0) {
            alert('Please select at least one item to update.');
            return false;
        }
        
        const statusSelect = document.getElementById('statusSelect');
        console.log('Status select value:', statusSelect ? statusSelect.value : 'not found');
        
        if (!statusSelect) {
            alert('Status dropdown not found.');
            return false;
        }
        
        if (statusSelect.value === '' || statusSelect.value === null) {
            alert('Please select a valid status.');
            return false;
        }
        
        console.log('Form validation passed. Submitting with status:', statusSelect.value);
        return true;
    } catch (e) {
        console.error('Form validation error:', e);
        alert('An error occurred during validation: ' + e.message);
        return false;
    }
}

function handleBulkDelete() {
    const checkboxes = document.querySelectorAll('input[name="inventoryItemIds"]:checked');
    if (checkboxes.length === 0) {
        alert('Please select at least one item to delete.');
        return;
    }
    
    if (confirm('Are you sure you want to delete ' + checkboxes.length + ' item(s)? This action cannot be undone.')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '@Url.Action("DeleteMultipleInventoryItems")';
        
        // Add anti-forgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = '__RequestVerificationToken';
        tokenInput.value = token;
        form.appendChild(tokenInput);
        
        // Add selected item IDs
        checkboxes.forEach(checkbox => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'inventoryItemIds';
            input.value = checkbox.value;
            form.appendChild(input);
        });
        
        document.body.appendChild(form);
        form.submit();
    }
}
</script>
