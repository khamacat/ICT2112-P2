@{
    ViewData["Title"] = "Create Clearance Batch";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h1 class="mb-4"><i class="bi bi-plus-circle"></i> Create Clearance Batch</h1>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="CreateBatch" method="post">
            <div class="mb-3">
                <label for="batchName" class="form-label">Batch Name</label>
                <input type="text" class="form-control" id="batchName" name="batchName"
                       placeholder="e.g. 2026 Q1 Clearance Sale" required />
            </div>
            <div class="mb-3">
                <label for="clearanceDate" class="form-label">Clearance Date</label>
                <input type="date" class="form-control" id="clearanceDate" name="clearanceDate" required />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg"></i> Create Batch
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
