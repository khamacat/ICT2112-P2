@model ProRental.Domain.Entities.Clearancebatch
@{
    ViewData["Title"] = "Batch: " + Model.GetBatchName();
    var items = ViewBag.ClearanceItems as List<ProRental.Domain.Entities.Clearanceitem>
                ?? new List<ProRental.Domain.Entities.Clearanceitem>();
    
    var itemDetails = ViewBag.ItemDetails as Dictionary<int, (string ProductName, string SerialNumber)>
                      ?? new Dictionary<int, (string ProductName, string SerialNumber)>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="bi bi-box-seam"></i> @Model.GetBatchName()</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Batches
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle"></i> @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Batch Info Card -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <small class="text-muted">Batch ID</small>
                <p class="fw-bold">#@Model.GetClearanceBatchId()</p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Clearance Date</small>
                <p class="fw-bold">@(Model.GetClearanceDate()?.ToString("dd MMM yyyy") ?? "—")</p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Created</small>
                <p class="fw-bold">@Model.GetCreatedDate().ToString("dd MMM yyyy")</p>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Status</small>
                <p>
                    @{
                        var statusClass = Model.GetStatus() switch
                        {
                            ProRental.Domain.Enums.ClearanceBatchStatus.SCHEDULED => "bg-warning text-dark",
                            ProRental.Domain.Enums.ClearanceBatchStatus.ACTIVE => "bg-success",
                            ProRental.Domain.Enums.ClearanceBatchStatus.CLOSED => "bg-secondary",
                            _ => "bg-info"
                        };
                    }
                    <span class="badge @statusClass fs-6">@Model.GetStatus()</span>
                </p>
            </div>
        </div>

        <!-- Lifecycle Actions -->
        <div class="d-flex gap-2 mt-2">
            @if (Model.GetStatus() == ProRental.Domain.Enums.ClearanceBatchStatus.SCHEDULED)
            {
                <form asp-action="ActivateBatch" method="post">
                    <input type="hidden" name="id" value="@Model.GetClearanceBatchId()" />
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="bi bi-play-fill"></i> Activate Batch
                    </button>
                </form>
            }
            @if (Model.GetStatus() == ProRental.Domain.Enums.ClearanceBatchStatus.ACTIVE)
            {
                <form asp-action="CloseBatch" method="post"
                      onsubmit="return confirm('Close this batch? This action cannot be undone.');">
                    <input type="hidden" name="id" value="@Model.GetClearanceBatchId()" />
                    <button type="submit" class="btn btn-secondary btn-sm">
                        <i class="bi bi-stop-fill"></i> Close Batch
                    </button>
                </form>
            }
            @if (Model.GetStatus() != ProRental.Domain.Enums.ClearanceBatchStatus.CLOSED)
            {
                <a asp-action="AddItems" asp-route-batchId="@Model.GetClearanceBatchId()"
                   class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-plus-lg"></i> Add Items
                </a>
            }
        </div>
    </div>
</div>

<!-- Items Table -->
<h4 class="mb-3">
    <i class="bi bi-list-ul"></i> Clearance Items
    <span class="badge bg-primary">@items.Count</span>
</h4>

@if (items.Count == 0)
{
    <div class="text-center py-4 text-muted">
        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
        <p class="mt-2">No items in this batch yet.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Item ID</th>
                    <th>Product</th>
                    <th>Inventory ID</th>
                    <th>Serial No.</th>
                    <th>Rec. Price</th>
                    <th>Final Price</th>
                    <th>Sale Date</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    var itemStatusClass = item.GetStatus() == ProRental.Domain.Enums.ClearanceStatus.SOLD
                        ? "bg-info" : "bg-primary";
                        
                    var itemId = item.GetClearanceItemId();
                    var details = itemDetails.ContainsKey(itemId) ? itemDetails[itemId] : ("Unknown", "Unknown");

                    <tr>
                        <td>@itemId</td>
                        <td class="fw-bold">@details.Item1</td>
                        <td>@item.GetInventoryItemId()</td>
                        <td><small class="text-muted">@details.Item2</small></td>
                        <td>@(item.GetRecommendedPrice()?.ToString("C") ?? "—")</td>
                        <td>@(item.GetFinalPrice()?.ToString("C") ?? "—")</td>
                        <td>@(item.GetSaleDate()?.ToString("dd MMM yyyy") ?? "—")</td>
                        <td><span class="badge @itemStatusClass">@item.GetStatus()</span></td>
                        <td class="text-end">
                            @if (item.GetStatus() != ProRental.Domain.Enums.ClearanceStatus.SOLD
                                 && Model.GetStatus() != ProRental.Domain.Enums.ClearanceBatchStatus.CLOSED)
                            {
                                <!-- Record Sale -->
                                <button type="button" class="btn btn-sm btn-outline-success"
                                        data-bs-toggle="modal"
                                        data-bs-target="#saleModal-@item.GetClearanceItemId()">
                                    <i class="bi bi-cash-coin"></i> Sell
                                </button>

                                <!-- Remove Item -->
                                <form asp-action="RemoveItem" method="post" class="d-inline"
                                      onsubmit="return confirm('Remove this item from the batch?');">
                                    <input type="hidden" name="clearanceItemId" value="@item.GetClearanceItemId()" />
                                    <input type="hidden" name="batchId" value="@Model.GetClearanceBatchId()" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>

                                <!-- Sale Modal -->
                                <div class="modal fade" id="saleModal-@item.GetClearanceItemId()" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form asp-action="RecordSale" method="post">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Record Sale — Item #@item.GetClearanceItemId()</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p class="text-muted">
                                                        Recommended price: <strong>@(item.GetRecommendedPrice()?.ToString("C") ?? "N/A")</strong>
                                                    </p>
                                                    <input type="hidden" name="clearanceItemId" value="@item.GetClearanceItemId()" />
                                                    <input type="hidden" name="batchId" value="@Model.GetClearanceBatchId()" />
                                                    <div class="mb-3">
                                                        <label class="form-label">Final Sale Price</label>
                                                        <input type="number" step="0.01" min="0" name="finalPrice"
                                                               class="form-control" required
                                                               value="@(item.GetRecommendedPrice()?.ToString("F2") ?? "")" />
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-success">
                                                        <i class="bi bi-check-lg"></i> Confirm Sale
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
