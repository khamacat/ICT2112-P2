@{
    ViewData["Title"] = "Add Items to Batch";
    var batchId = ViewBag.BatchId;
    var batchName = ViewBag.BatchName;
    var noMoveItems = (List<ProRental.Domain.Entities.Inventoryitem>)ViewBag.NoMoveItems;
    var productNames = (Dictionary<int, string>)ViewBag.ProductNames;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-plus-lg"></i> Add Items to: @batchName</h1>
    <a asp-action="BatchDetails" asp-route-id="@batchId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Back to Batch
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        @if (noMoveItems == null || noMoveItems.Count == 0)
        {
            <div class="alert alert-info mb-0">
                <i class="bi bi-info-circle"></i> No eligible items found. Items must be inactive for 24+ months to qualify for clearance.
            </div>
        }
        else
        {
            <form asp-action="AddItems" method="post">
                <input type="hidden" name="batchId" value="@batchId" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Select Inventory Items</label>
                    <p class="text-muted small">
                        Choose from inventory items that have been inactive for 24+ months (no-move items).
                    </p>
                </div>

                <div id="itemIdsContainer">
                    <div class="inventory-row mb-3">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-box-seam"></i></span>
                            <select class="form-select" name="inventoryItemIds" required>
                                <option value="" disabled selected>-- Select an item --</option>
                                @foreach (var item in noMoveItems)
                                {
                                    var itemId = item.GetInventoryItemId();
                                    var serial = item.GetSerialNumber();
                                    var name = productNames.ContainsKey(itemId) ? productNames[itemId] : "Unknown";
                                    <option value="@itemId">@name — SN: @serial (ID: @itemId)</option>
                                }
                            </select>
                            <button type="button" class="btn btn-outline-danger" onclick="removeRow(this)" style="display:none">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn btn-outline-primary btn-sm mb-3" onclick="addRow()">
                    <i class="bi bi-plus-circle"></i> Add Another Item
                </button>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Add Items to Batch
                    </button>
                    <a asp-action="BatchDetails" asp-route-id="@batchId" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Template for the select options (built server-side, reused client-side)
        const selectOptionsHtml = document.querySelector('.inventory-row select')?.innerHTML ?? '';

        function addRow() {
            const container = document.getElementById('itemIdsContainer');
            const div = document.createElement('div');
            div.className = 'inventory-row mb-3';
            div.innerHTML = `
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-box-seam"></i></span>
                    <select class="form-select" name="inventoryItemIds" required>
                        ${selectOptionsHtml}
                    </select>
                    <button type="button" class="btn btn-outline-danger" onclick="removeRow(this)">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            `;
            container.appendChild(div);
        }

        function removeRow(btn) {
            btn.closest('.inventory-row').remove();
        }
    </script>
}

