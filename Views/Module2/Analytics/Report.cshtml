@model ProRental.Domain.Entities.Reportexport
@{
    ViewData["Title"] = "Report — " + Model.GetTitle();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@Model.GetTitle()</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Report ID</dt>
                <dd class="col-sm-9">@Model.GetReportID()</dd>
                <dt class="col-sm-3">Linked Analytics ID</dt>
                <dd class="col-sm-9">
                    <a asp-action="Details" asp-route-id="@Model.GetRefAnalyticsID()">
                        #@Model.GetRefAnalyticsID()
                    </a>
                </dd>
                <dt class="col-sm-3">Visual Type</dt>
                <dd class="col-sm-9">@Model.GetVisualType()</dd>
                <dt class="col-sm-3">File Format</dt>
                <dd class="col-sm-9">@Model.GetFileFormat()</dd>
            </dl>
        </div>
        <div class="card-footer d-flex gap-2">
            <a asp-action="ExportReport" asp-route-id="@Model.GetReportID()"
               asp-route-format="@Model.GetFileFormat()" class="btn btn-success">
                ⬇ Export @Model.GetFileFormat()
            </a>
            <button class="btn btn-outline-danger"
                    onclick="document.getElementById('deleteForm').submit()">
                Delete Report
            </button>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Edit Report</div>
        <div class="card-body">
            <form method="post" asp-action="UpdateReport">
                <input type="hidden" name="id" value="@Model.GetReportID()" />
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" name="title" class="form-control" value="@Model.GetTitle()" required />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Visual Type</label>
                        <select name="visualType" class="form-select">
                            <option value="TABLE">Table</option>
                            <option value="BAR">Bar</option>
                            <option value="LINE">Line</option>
                            <option value="PIE">Pie</option>
                            <option value="COLUMN">Column</option>
                            <option value="AREA">Area</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">File Format</label>
                        <select name="fileFormat" class="form-select">
                            <option value="PDF">PDF</option>
                            <option value="XLSX">XLSX</option>
                            <option value="CSV">CSV</option>
                        </select>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" asp-action="DeleteReport">
    <input type="hidden" name="id" value="@Model.GetReportID()" />
</form>
