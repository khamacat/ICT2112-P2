@model ProRental.Controllers.AnalyticsDetailsViewModel
@{
    var a = Model.Analytic;
    ViewData["Title"] = "Analytics #" + a.GetID();
    var typeBadge = a.GetAnalyticsType() switch {
        "DAILY"     => "bg-info",
        "SUPTREND"  => "bg-warning text-dark",
        "PRODTREND" => "bg-success",
        _           => "bg-secondary"
    };
    var isDaily     = a.GetAnalyticsType() == "DAILY";
    var refLabel    = isDaily ? "" : (a.GetAnalyticsType() == "SUPTREND" ? "Supplier" : "Product");
    var valueLabel  = a.GetAnalyticsType() == "SUPTREND" ? "Supplier Reliability" : "Turnover Rate";

    // Adjust for SGT display
    var dispStart = a.GetStartDate()?.AddHours(8);
    var dispEnd   = a.GetEndDate()?.AddHours(8);
    var dateLabel = dispStart?.ToString("yyyy-MM-dd") == dispEnd?.ToString("yyyy-MM-dd")
        ? dispStart?.ToString("yyyy-MM-dd")
        : $"{dispStart?.ToString("yyyy-MM-dd")} to {dispEnd?.ToString("yyyy-MM-dd")}";
    var prefilledTitle = isDaily
        ? $"Daily — {dateLabel}"
        : $"{a.GetRefPrimaryName()} — {dateLabel}";

    // Pre-compute selected states for update form
    var r = Model.ExistingReport;
    var vtOpts = r != null
        ? Enum.GetValues<ProRental.Domain.Enums.VisualType>()
              .Select(vt => (val: vt.ToString(), sel: r.GetVisualType() == vt ? "selected" : ""))
              .ToList()
        : new List<(string val, string sel)>();
    var ffOpts = r != null
        ? Enum.GetValues<ProRental.Domain.Enums.FileFormat>()
              .Select(ff => (val: ff.ToString(), sel: r.GetFileFormat() == ff ? "selected" : ""))
              .ToList()
        : new List<(string val, string sel)>();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Analytics #@a.GetID() <span class="badge @typeBadge fs-6 ms-2">@a.GetAnalyticsType()</span></h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
    </div>

    <!-- Summary -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Date Range</dt>
                <dd class="col-sm-9">@dispStart?.ToString("yyyy-MM-dd") — @dispEnd?.ToString("yyyy-MM-dd")</dd>
                <dt class="col-sm-3">Loans</dt>
                <dd class="col-sm-9">@a.GetLoanAmt()</dd>
                <dt class="col-sm-3">Returns</dt>
                <dd class="col-sm-9">@a.GetReturnAmt()</dd>
                @if (!isDaily)
                {
                    <dt class="col-sm-3">@refLabel Name</dt>
                    <dd class="col-sm-9">@a.GetRefPrimaryName() @(a.GetRefPrimaryID().HasValue ? $"(ID: {a.GetRefPrimaryID()})" : "")</dd>
                    <dt class="col-sm-3">@valueLabel</dt>
                    <dd class="col-sm-9">@a.GetRefValue()?.ToString("0.00")</dd>
                }
                else
                {
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@a.GetRefPrimaryName()</dd>
                }
            </dl>
        </div>
    </div>

    <!-- Transaction Logs -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header fw-semibold">
            <i class="bi bi-list-ul me-2"></i>Transaction Logs in this Period
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Log ID</th><th>Type</th><th>Date</th>
                        <th>Supplier</th><th>Product</th><th>Summary</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.TransactionLogs)
                    {
                        var logBadge = log.LogType switch {
                            "LOAN"           => "bg-primary",
                            "RETURN"         => "bg-warning text-dark",
                            "PURCHASE_ORDER" => "bg-success",
                            "RENTAL_ORDER"   => "bg-info text-dark",
                            "CLEARANCE"      => "bg-secondary",
                            _                => "bg-dark"
                        };
                        <tr>
                            <td>#@log.LogID</td>
                            <td><span class="badge @logBadge">@log.LogType</span></td>
                            <td>@log.CreatedAt.AddHours(8).ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(log.SupplierName ?? "—")</td>
                            <td>@(log.ProductName  ?? "—")</td>
                            <td class="text-muted small">@log.Summary</td>
                        </tr>
                    }
                    @if (!Model.TransactionLogs.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-3">No logs found for this period.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Report section -->
    @if (Model.ExistingReport is not null)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark-text me-2"></i>Report — @r!.GetTitle()</span>
                <div class="d-flex gap-2">
                    <a asp-action="ExportReport" asp-route-id="@r.GetReportID()"
                       class="btn btn-sm btn-success">
                        <i class="bi bi-download me-1"></i>Export @r.GetFileFormat()
                    </a>
                    <button class="btn btn-sm btn-outline-danger"
                            onclick="document.getElementById('deleteReportForm').submit()">Delete</button>
                </div>
            </div>
            <div class="card-body">
                @if (r.GetFileFormat() == ProRental.Domain.Enums.FileFormat.PDF)
                {
                    <iframe src="@Url.Action("ExportReport", new { id = r.GetReportID() })"
                            width="100%" height="400px" class="border rounded"></iframe>
                }
                else
                {
                    <!-- Table preview showing transaction log data -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm">
                            <thead class="table-light">
                                <tr><th>Log ID</th><th>Type</th><th>Date</th><th>Supplier</th><th>Product</th><th>Summary</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.TransactionLogs)
                                {
                                    <tr>
                                        <td>#@log.LogID</td>
                                        <td>@log.LogType</td>
                                        <td>@log.CreatedAt.AddHours(8).ToString("yyyy-MM-dd")</td>
                                        <td>@(log.SupplierName ?? "—")</td>
                                        <td>@(log.ProductName  ?? "—")</td>
                                        <td>@log.Summary</td>
                                    </tr>
                                }
                                @if (!Model.TransactionLogs.Any())
                                {
                                    <tr><td colspan="6" class="text-center text-muted">No logs</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <hr />
                <h6 class="fw-semibold">Update Report</h6>
                <form method="post" asp-action="UpdateReport" class="row g-2">
                    <input type="hidden" name="id"             value="@r.GetReportID()" />
                    <input type="hidden" name="refAnalyticsID" value="@a.GetID()" />
                    <div class="col-md-4">
                        <input type="text" name="title" class="form-control"
                               value="@r.GetTitle()" placeholder="Report title" required />
                    </div>
                    <div class="col-md-3">
                        <select name="visualType" class="form-select">
                            @foreach (var opt in vtOpts)
                            {
                                <option value="@opt.val" selected="@opt.sel">@opt.val</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select name="fileFormat" class="form-select">
                            @foreach (var opt in ffOpts)
                            {
                                <option value="@opt.val" selected="@opt.sel">@opt.val</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Update</button>
                    </div>
                </form>
            </div>
        </div>

        <form id="deleteReportForm" method="post" asp-action="DeleteReport">
            <input type="hidden" name="id"             value="@r.GetReportID()" />
            <input type="hidden" name="refAnalyticsID" value="@a.GetID()" />
        </form>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                <i class="bi bi-plus-circle me-2"></i>Generate Report
            </div>
            <div class="card-body">
                <form method="post" asp-action="GenerateReport" class="row g-3">
                    <input type="hidden" name="refAnalyticsID" value="@a.GetID()" />
                    <div class="col-md-4">
                        <label class="form-label">Title</label>
                        <input type="text" name="title" class="form-control"
                               value="@prefilledTitle" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Visual Type</label>
                        <select name="visualType" class="form-select">
                            @foreach (var vt in Enum.GetValues<ProRental.Domain.Enums.VisualType>())
                            { <option value="@vt">@vt</option> }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">File Format</label>
                        <select name="fileFormat" class="form-select">
                            @foreach (var ff in Enum.GetValues<ProRental.Domain.Enums.FileFormat>())
                            { <option value="@ff">@ff</option> }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Generate</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
