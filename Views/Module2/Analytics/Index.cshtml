@model IEnumerable<ProRental.Domain.Entities.Analytic>
@{
    ViewData["Title"] = "Analytics";
}

<div class="container mt-4">
    <h2 class="mb-3">Analytics</h2>

    <form method="get" asp-action="ByDateRange" class="row g-2 mb-4">
        <div class="col-auto">
            <input type="date" name="start" class="form-control" />
        </div>
        <div class="col-auto">
            <input type="date" name="end" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary">Filter by Date</button>
        </div>
    </form>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th><th>Type</th><th>Start</th><th>End</th>
                <th>Loan</th><th>Return</th><th>Ref Name</th><th>Value</th><th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.GetID()</td>
                    <td>
                        <span class="badge @(item.GetAnalyticsType() == "DAILY" ? "bg-info" :
                                             item.GetAnalyticsType() == "SUPTREND" ? "bg-warning text-dark" :
                                             "bg-success")">
                            @item.GetAnalyticsType()
                        </span>
                    </td>
                    <td>@item.GetStartDate()?.ToString("yyyy-MM-dd")</td>
                    <td>@item.GetEndDate()?.ToString("yyyy-MM-dd")</td>
                    <td>@item.GetLoanAmt()</td>
                    <td>@item.GetReturnAmt()</td>
                    <td>@item.GetRefPrimaryName()</td>
                    <td>@item.GetRefValue()?.ToString("C")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.GetID()"
                           class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Any())
    {
        <div class="alert alert-info">No analytics records found.</div>
    }
</div>
