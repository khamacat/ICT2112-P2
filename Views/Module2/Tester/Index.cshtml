@{
    ViewData["Title"] = "Inventory Service Facade Tester";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Inventory Service Tester</h1>
        <p class="text-muted">Bypass the UI and directly invoke the coordination methods for the Live Demo.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fs-5 shadow-sm"><i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger fs-5 shadow-sm"><i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="row g-4 justify-content-center">
        
        <div class="col-md-6">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-cart-check"></i> Step 1: Process Loan (Alert Demo)</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Simulates Module 1 completing a checkout. <strong>Demo Target:</strong> Order 4 requests 4x Sony FX3s (Product 5). Processing this will drop available stock to 1, triggering the 40% Low Stock Alert!</p>
                    
                    <form asp-action="TestProcessLoan" method="post">
                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label class="form-label fw-bold">Order ID</label>
                                <input type="number" name="orderId" class="form-control" value="4" required />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Customer ID</label>
                                <input type="number" name="customerId" class="form-control" value="4" required />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Product ID</label>
                                <input type="number" name="productId" class="form-control" value="5" required />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Quantity</label>
                                <input type="number" name="quantity" class="form-control" value="4" required />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold">Execute ProcessLoan()</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0"><i class="bi bi-arrow-return-left"></i> Step 2: Trigger Return</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Simulates Staff receiving a physical return. <strong>Demo Target:</strong> Run this on Order 4 after processing the loan. It will push all 4 items into the Return Pipeline (Damage Inspection).</p>
                    
                    <form asp-action="TestTriggerReturn" method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Order ID</label>
                            <input type="number" name="orderId" class="form-control" value="4" required />
                            <div class="form-text text-muted">Use Order 4 (if you just processed it) or Order 3 (which is already ON_LOAN historically).</div>
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold">Execute TriggerReturnProcess()</button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>