@model ProRental.Domain.Entities.Replenishmentrequest
@{
    ViewData["Title"] = $"Request #{Model.RequestId} Details";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="List">Replenishment Requests</a></li>
            <li class="breadcrumb-item active">Request #@Model.RequestId</li>
        </ol>
    </nav>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Request Details</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Request ID</dt>
                    <dd class="col-sm-7">#@Model.RequestId</dd>

                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">
                        @switch (Model.Status)
                        {
                            case ProRental.Domain.Enums.ReplenishmentStatus.DRAFT:
                                <span class="badge bg-secondary">Draft</span>
                                break;
                            case ProRental.Domain.Enums.ReplenishmentStatus.SUBMITTED:
                                <span class="badge bg-primary">Submitted</span>
                                break;
                            case ProRental.Domain.Enums.ReplenishmentStatus.COMPLETED:
                                <span class="badge bg-success">Completed</span>
                                break;
                            case ProRental.Domain.Enums.ReplenishmentStatus.CANCELLED:
                                <span class="badge bg-danger">Cancelled</span>
                                break;
                        }
                    </dd>

                    <dt class="col-sm-5">Requested By</dt>
                    <dd class="col-sm-7">@Model.RequestedBy</dd>

                    <dt class="col-sm-5">Created At</dt>
                    <dd class="col-sm-7">@Model.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</dd>

                    @if (Model.CompletedAt.HasValue)
                    {
                        <dt class="col-sm-5">Completed At</dt>
                        <dd class="col-sm-7">@Model.CompletedAt?.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-5">Completed By</dt>
                        <dd class="col-sm-7">@Model.CompletedBy</dd>
                    }
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Actions</h5>
            </div>
            <div class="card-body d-grid gap-2">
                @if (Model.CanEdit())
                {
                    <a asp-action="Form" asp-route-id="@Model.RequestId" class="btn btn-primary w-100">
                        <i class="bi bi-pencil me-1"></i>Edit Request
                    </a>
                }

                @if (Model.Status == ProRental.Domain.Enums.ReplenishmentStatus.SUBMITTED)
                {
                    <form asp-action="Complete" asp-route-id="@Model.RequestId" method="post">
                        @Html.AntiForgeryToken()
                        <div class="input-group">
                            <input type="text" class="form-control" name="completedBy"
                                   placeholder="Staff ID" required />
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle me-1"></i>Complete
                            </button>
                        </div>
                    </form>

                    <form asp-action="Cancel" asp-route-id="@Model.RequestId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100"
                                onclick="return confirm('Are you sure you want to cancel this request?')">
                            <i class="bi bi-x-circle me-1"></i>Cancel Request
                        </button>
                    </form>
                }

                <a asp-action="List" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Line Items</h5>
                <span class="badge bg-primary">@(Model.Lineitems?.Count() ?? 0) items</span>
            </div>
            <div class="card-body">
                @if (Model.Lineitems != null && Model.Lineitems.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Product ID</th>
                                    <th>Quantity</th>
                                    <th>Reason</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Lineitems)
                                {
                                    <tr>
                                        <td>
                                            <strong>#@item.ProductId</strong>
                                            @if (item.Product != null)
                                            {
                                                <br /><small class="text-muted">@item.Product</small>
                                            }
                                        </td>
                                        <td>@item.QuantityRequest</td>
                                        <td>
                                            <span class="badge bg-info">@item.Reason</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.GetRemarks()))
                                            {
                                                @item.GetRemarks()
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox display-4"></i>
                        <p class="mt-3 mb-0">No items in this request.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
