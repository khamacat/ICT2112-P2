@{
    ViewData["Title"] = "Staff Portal";
    var userName = Context.Session.GetString("UserName") ?? "Staff Member";
    var userRole = Context.Session.GetString("UserRole") ?? "STAFF";
    var isAdmin = userRole.Equals("ADMIN", StringComparison.OrdinalIgnoreCase);
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-9 col-lg-7">

        <!-- Success banner -->
        <div class="text-center mb-5">
            <div class="mb-3">
                <span class="badge @(isAdmin ? "bg-danger" : "bg-warning text-dark") px-3 py-2 fs-6">
                    <i class="bi bi-shield-fill-check me-1"></i>
                    @(isAdmin ? "Administrator" : "Staff") Session Active
                </span>
            </div>
            <h1 class="h2 fw-bold">Welcome back, @userName</h1>
            <p class="text-muted">You are signed in to the Staff &amp; Admin Portal.</p>
        </div>

        <!-- Quick-access cards -->
        <div class="row g-3 mb-4">

            <div class="col-12 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-4">
                        <span class="fs-2 text-primary"><i class="bi bi-cart-check-fill"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Order Processing</h6>
                            <p class="text-muted small mb-2">View and manage rental orders.</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-primary">Go</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-4">
                        <span class="fs-2 text-success"><i class="bi bi-box-seam-fill"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Inventory</h6>
                            <p class="text-muted small mb-2">Track stock levels and items.</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-success">Go</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-4">
                        <span class="fs-2 text-warning"><i class="bi bi-arrow-return-left"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Returns</h6>
                            <p class="text-muted small mb-2">Process customer return requests.</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-warning">Go</a>
                        </div>
                    </div>
                </div>
            </div>

            @if (isAdmin)
            {
                <div class="col-12 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm border-danger border-opacity-25">
                        <div class="card-body d-flex align-items-start gap-3 p-4">
                            <span class="fs-2 text-danger"><i class="bi bi-people-fill"></i></span>
                            <div>
                                <h6 class="fw-semibold mb-1">User Management</h6>
                                <p class="text-muted small mb-2">Manage staff and customer accounts.</p>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-danger">Go</a>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>

        <!-- Session info -->
        <div class="card border-0 bg-light">
            <div class="card-body px-4 py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="small text-muted">
                    <i class="bi bi-person-circle me-1"></i>
                    Logged in as <strong>@userName</strong>
                    &nbsp;·&nbsp;
                    <span class="badge @(isAdmin ? "bg-danger" : "bg-warning text-dark")">@userRole</span>
                </div>
                <form asp-controller="Module1" asp-action="Logout" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>
