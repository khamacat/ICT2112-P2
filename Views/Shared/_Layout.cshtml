@*
    =========================================================================
    ProRental — Shared Layout  (_Layout.cshtml)
    =========================================================================

    STRUCTURE OVERVIEW
    ------------------
    <head>          CSS (Bootstrap → Bootstrap Icons → site.css), viewport meta
    <header>        Top navbar — add new nav-item links here for new sections
    <div.container> Main content area — @RenderBody() injects each view here
    <footer>        Sticky footer — markup stays simple, styled via site.css
    Scripts block   jQuery → Bootstrap JS → site.js → @section Scripts{}

    DESIGN RULES FOR DEVELOPERS
    ---------------------------
    1. Bootstrap 5.3 utility classes ONLY inside views — no inline styles.
    2. Brand colour and CSS variable overrides live in wwwroot/css/site.css.
       Do NOT hardcode colour values (#hex / rgb) in views or here.
    3. Icons: use Bootstrap Icons — class="bi bi-<name>".
       Full icon reference: https://icons.getbootstrap.com/
    4. The .container wrapper here provides the page's outer padding/max-width.
       Do NOT add another .container inside individual view files.
    5. If a view needs page-specific CSS or JS, use the "Scripts" section:
           @section Scripts { <script src="..."></script> }
    =========================================================================
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProRental</title>

    <!-- CSS load order: Bootstrap base → Bootstrap Icons → project overrides -->
    <!-- 1. Bootstrap 5.3.3 — grid, components, utilities (local via libman) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- 2. Bootstrap Icons 1.11.3 — use class="bi bi-<name>" in any view -->
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <!-- 3. site.css — brand theme (eco-green) + project-specific overrides -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @* ================================================================
         NAVBAR — Top navigation bar
         Add new <li class="nav-item"> entries here to extend the nav menu.
         See Bootstrap Navbar docs: https://getbootstrap.com/docs/5.3/components/navbar/
         ================================================================ 
    *@
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">ProRental</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Clearance" asp-action="Index">
                                <i class="bi bi-tags"></i> Clearance</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="StaffInventory" asp-action="DisplayInventoryList">Stock</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="ReturnProcessing" asp-action="DisplayReturnRequests">Returns</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ================================================================
         MAIN CONTENT — Individual view output is injected here via RenderBody().
         Do NOT add additional containers or wrappers inside view files.
         ================================================================ -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ================================================================
         FOOTER — Sticky footer (pinned to bottom via site.css .footer rules)
         ================================================================ -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; @DateTime.Now.Year - ProRental
        </div>
    </footer>

    <!-- ================================================================
         SCRIPTS — Load order matters; do not rearrange these.
         jQuery must come before Bootstrap JS.
         Add view-specific scripts via @@section Scripts { } in the view file.
         ================================================================ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
